<Application
    x:Class="wincast.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wincast">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Premium Dark Theme Palette -->
            <SolidColorBrush x:Key="SearchBoxBackground" Color="#202026" Opacity="0.7"/>
            <SolidColorBrush x:Key="SearchBoxBorder" Color="#30303A" Opacity="0.6"/>
            <SolidColorBrush x:Key="ItemHoverBackground" Color="#353545" Opacity="0.4"/>
            <SolidColorBrush x:Key="ItemActiveBackground" Color="#4A4A5A" Opacity="0.5"/>
            <SolidColorBrush x:Key="AccentColor" Color="#5856D6"/> 
            <SolidColorBrush x:Key="AccentHoverColor" Color="#6E6CE6"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA"/>
            <SolidColorBrush x:Key="TextMuted" Color="#71717A"/>
            <SolidColorBrush x:Key="DetailPaneBackground" Color="#18181F" Opacity="0.6"/>
            
            <!-- Typography -->
            <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets, sans-serif</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
