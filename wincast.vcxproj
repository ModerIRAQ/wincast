  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <!-- Fix: The XAML compiler needs WinUI .winmd + Windows SDK contracts in @(ReferencePath).
       Native C++ projects don't auto-resolve @(Reference) -> @(ReferencePath) like managed projects. -->
  <PropertyGroup>
    <_WinUIWinmdDir>$([MSBuild]::NormalizePath('$(NuGetPackageRoot)', 'microsoft.windowsappsdk', '1.6.241114003', 'lib', 'uap10.0'))\</_WinUIWinmdDir>
    <_WinUIWinmdDir18362>$([MSBuild]::NormalizePath('$(NuGetPackageRoot)', 'microsoft.windowsappsdk', '1.6.241114003', 'lib', 'uap10.0.18362'))\</_WinUIWinmdDir18362>
  </PropertyGroup>
  <Target Name="_AddWinUIWinmdToReferencePath" BeforeTargets="MarkupCompilePass1;MarkupCompilePass2">
    <ItemGroup>
      <!-- All WinUI/App SDK winmd files — required for complete type universe resolution -->
      <ReferencePath Include="$(_WinUIWinmdDir)*.winmd" />
      <!-- Additional SDK winmd files (Microsoft.UI, Microsoft.Graphics, Microsoft.Foundation) -->
      <ReferencePath Include="$(_WinUIWinmdDir18362)*.winmd" />
      <!-- Windows SDK platform metadata -->
      <ReferencePath Include="$(WindowsSdkDir)References\$(WindowsTargetPlatformVersion)\Windows.Foundation.FoundationContract\4.0.0.0\Windows.Foundation.FoundationContract.winmd"
                     Condition="Exists('$(WindowsSdkDir)References\$(WindowsTargetPlatformVersion)\Windows.Foundation.FoundationContract\4.0.0.0\Windows.Foundation.FoundationContract.winmd')" />
      <ReferencePath Include="$(WindowsSdkDir)References\$(WindowsTargetPlatformVersion)\Windows.Foundation.UniversalApiContract\19.0.0.0\Windows.Foundation.UniversalApiContract.winmd"
                     Condition="Exists('$(WindowsSdkDir)References\$(WindowsTargetPlatformVersion)\Windows.Foundation.UniversalApiContract\19.0.0.0\Windows.Foundation.UniversalApiContract.winmd')" />
      <ReferencePath Include="$(WindowsSdkDir)UnionMetadata\$(WindowsTargetPlatformVersion)\Windows.winmd"
                     Condition="Exists('$(WindowsSdkDir)UnionMetadata\$(WindowsTargetPlatformVersion)\Windows.winmd')" />
      <!-- Search paths so XAML compiler can resolve assembly refs by name.
           The .NET Framework path is needed because the XAML compiler also looks for mscorlib.dll. -->
      <ReferenceAssemblyPaths Include="$(_WinUIWinmdDir)" />
      <ReferenceAssemblyPaths Include="$(_WinUIWinmdDir18362)" />
      <ReferenceAssemblyPaths Include="$(WindowsSdkDir)UnionMetadata\$(WindowsTargetPlatformVersion)\" />
      <ReferenceAssemblyPaths Include="$(MSBuildFrameworkToolsPath)" />
    </ItemGroup>
  </Target>
