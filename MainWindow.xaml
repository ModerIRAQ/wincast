<Window
    x:Class="WinCast.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinCast.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinCast">
    <Border x:Name="RootSurface"
            BorderBrush="{StaticResource SearchBoxBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Background="{StaticResource AppBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- SEARCH BAR -->
            <Grid Grid.Row="0" Margin="18,16,18,14" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon x:Name="SearchIcon"
                          Grid.Column="0"
                          Glyph="&#xE721;"
                          FontFamily="{StaticResource IconFont}"
                          FontSize="18"
                          Foreground="{StaticResource AccentColor}"
                          VerticalAlignment="Center"/>
                <Button x:Name="AiModeBadge"
                        Grid.Column="0"
                        Visibility="Collapsed"
                        Background="{StaticResource AccentDim}"
                        BorderBrush="{StaticResource AccentBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,4,8,4"
                        Click="ExitAiModeButton_Click"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEF58;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource AccentColor}"/>
                        <TextBlock x:Name="AiModeBadgeText" Text="AI Mode" FontSize="12" FontFamily="{StaticResource DisplayFont}" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                        <FontIcon Glyph="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="8" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>
                </Button>
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         PlaceholderText="Search apps, calculate, run commands…"
                         FontSize="17"
                         FontFamily="{StaticResource DisplayFont}"
                         FontWeight="Light"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,4,0,4"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown">
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                        <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlForeground" Color="#F0F0FA"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#44445A"/>
                    </TextBox.Resources>
                </TextBox>
                <ProgressRing x:Name="IndexingRing"
                              Grid.Column="2"
                              Width="18" Height="18"
                              Foreground="{StaticResource AccentColor}"
                              IsActive="True"
                              Visibility="Visible"
                              VerticalAlignment="Center"/>
            </Grid>
            <!-- DIVIDER -->
            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource DividerBrush}" Opacity="0.8"/>
            <!-- CONTENT AREA -->
            <Grid Grid.Row="2" x:Name="ContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0" x:Name="DetailColumn"/>
                </Grid.ColumnDefinitions>
                <!-- LEFT PANE -->
                <Grid Grid.Column="0">
                    <!-- DASHBOARD PANEL -->
                    <ScrollViewer x:Name="DashboardPanel"
                                  VerticalScrollBarVisibility="Hidden"
                                  Opacity="1">
                        <StackPanel Margin="18,18,18,14" Spacing="18">
                            <!-- Command hub header -->
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="148"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="5" VerticalAlignment="Center">
                                    <TextBlock x:Name="GreetingText"
                                               Text="Ready when you are"
                                               FontSize="24"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock x:Name="GreetingSubText"
                                               Text="Search apps, calculate, or run a command."
                                               FontSize="13"
                                               FontFamily="{StaticResource BodyFont}"
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,7,0,0">
                                        <Border CornerRadius="5"
                                                Padding="8,4,8,4"
                                                Background="{StaticResource SurfaceCard}"
                                                BorderBrush="{StaticResource SearchBoxBorder}"
                                                BorderThickness="1">
                                            <TextBlock x:Name="DashboardStatusText"
                                                       Text="Indexing apps"
                                                       FontSize="10"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                        <Border CornerRadius="5"
                                                Padding="8,4,8,4"
                                                Background="{StaticResource SurfaceCard}"
                                                BorderBrush="{StaticResource SearchBoxBorder}"
                                                BorderThickness="1">
                                            <TextBlock Text="Alt + Space"
                                                       FontSize="10"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{StaticResource SurfaceCard}"
                                        BorderBrush="{StaticResource SearchBoxBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12,14,12">
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="DashboardAppCountText"
                                                   Text="--"
                                                   FontSize="28"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentColor}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="DashboardAppCountLabel" Text="indexed apps"
                                                    FontSize="11"
                                                    FontFamily="{StaticResource BodyFont}"
                                                    Foreground="{StaticResource TextMuted}"
                                                    HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <!-- Quick actions -->
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="DashboardCommandsHeaderLabel" Text="COMMANDS"
                                            FontSize="10"
                                            FontFamily="{StaticResource DisplayFont}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextMuted}"
                                            CharacterSpacing="150"
                                            Margin="2,0,0,0"/>
                                <Grid ColumnSpacing="10" RowSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button x:Name="QuickCalcButton"
                                            Grid.Row="0" Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,11,12,11"
                                            Click="QuickCalcButton_Click">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE1D0;"
                                                      FontFamily="{StaticResource IconFont}"
                                                      FontSize="20"
                                                      Foreground="{StaticResource AccentColor}"
                                                      VerticalAlignment="Center"/>
                                             <StackPanel Grid.Column="1" Spacing="1">
                                                 <TextBlock x:Name="QuickCalcHeaderLabel" Text="Calculate"
                                                            FontSize="13"
                                                            FontFamily="{StaticResource DisplayFont}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource TextPrimary}"/>
                                                 <TextBlock x:Name="QuickCalcDescLabel" Text="Try 2 + 2"
                                                            FontSize="11"
                                                            FontFamily="{StaticResource BodyFont}"
                                                            Foreground="{StaticResource TextMuted}"/>
                                             </StackPanel>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="QuickBrowseButton"
                                            Grid.Row="0" Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,11,12,11"
                                            Click="QuickBrowseButton_Click">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE71D;"
                                                      FontFamily="{StaticResource IconFont}"
                                                      FontSize="20"
                                                      Foreground="{StaticResource CyanAccent}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock x:Name="QuickBrowseHeaderLabel" Text="Browse apps"
                                                           FontSize="13"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock x:Name="QuickBrowseDescLabel" Text="Open app list"
                                                           FontSize="11"
                                                           FontFamily="{StaticResource BodyFont}"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="QuickShellButton"
                                            Grid.Row="1" Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,11,12,11"
                                            Click="QuickShellButton_Click">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE756;"
                                                      FontFamily="{StaticResource IconFont}"
                                                      FontSize="20"
                                                      Foreground="{StaticResource GreenAccent}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock x:Name="QuickShellHeaderLabel" Text="Command"
                                                           FontSize="13"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock x:Name="QuickShellDescLabel" Text="Run with &gt;"
                                                           FontSize="11"
                                                           FontFamily="{StaticResource BodyFont}"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="QuickHelpButton"
                                            Grid.Row="1" Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,11,12,11"
                                            Click="QuickHelpButton_Click">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE897;"
                                                      FontFamily="{StaticResource IconFont}"
                                                      FontSize="20"
                                                      Foreground="{StaticResource OrangeAccent}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock x:Name="QuickHelpHeaderLabel" Text="Shortcuts"
                                                           FontSize="13"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock x:Name="QuickHelpDescLabel" Text="Search help"
                                                           FontSize="11"
                                                           FontFamily="{StaticResource BodyFont}"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            <!-- Recent Apps (populated from code-behind) -->
                            <StackPanel Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DashboardRecentHeaderLabel"
                                               Text="RECENT"
                                               FontSize="10"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}"
                                               CharacterSpacing="150"
                                               Margin="2,0,0,0"
                                               Grid.Column="0"/>
                                    <TextBlock x:Name="RecentSummaryText"
                                               Text="No launches yet"
                                               FontSize="10"
                                               FontFamily="{StaticResource BodyFont}"
                                               Foreground="{StaticResource TextMuted}"
                                               Grid.Column="1"/>
                                </Grid>
                                <StackPanel x:Name="RecentAppsSection" Spacing="3" Visibility="Collapsed">
                                    <StackPanel x:Name="RecentAppsContainer" Spacing="3"/>
                                </StackPanel>
                                <Border x:Name="RecentEmptyState"
                                        Background="{StaticResource SurfaceCard}"
                                        BorderBrush="{StaticResource SearchBoxBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,13,14,13">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE81C;"
                                                  FontFamily="{StaticResource IconFont}"
                                                  FontSize="18"
                                                  Foreground="{StaticResource TextMuted}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock x:Name="RecentEmptyTitleLabel" Text="Recent launches will appear here"
                                                       FontSize="13"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="RecentEmptyDescLabel" Text="Launch an app once and WinCast keeps it ready."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <!-- Starter examples -->
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="DashboardTryHeaderLabel" Text="TRY"
                                           FontSize="10"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"
                                           CharacterSpacing="150"
                                           Margin="2,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="notepad"
                                            FontSize="11"
                                            FontFamily="{StaticResource MonoFont}"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6,10,6"
                                            Click="ExampleNotepadButton_Click"/>
                                    <Button Content="(15 + 25) * 4"
                                            FontSize="11"
                                            FontFamily="{StaticResource MonoFont}"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6,10,6"
                                            Click="ExampleCalcButton_Click"/>
                                    <Button Content="&gt; ipconfig"
                                            FontSize="11"
                                            FontFamily="{StaticResource MonoFont}"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6,10,6"
                                            Click="ExampleShellButton_Click"/>
                                    <Button x:Name="ExampleAIButton"
                                            Content="- what is AI?"
                                            FontSize="11"
                                            FontFamily="{StaticResource MonoFont}"
                                            Background="{StaticResource SurfaceCard}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6,10,6"
                                            Click="ExampleAIButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- RESULTS PANEL -->
                    <Grid x:Name="ResultsPanel" Opacity="0" Visibility="Collapsed">
                        <ListView x:Name="ResultsListView"
                                  Margin="8,6,8,6"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="ResultsListView_ItemClick"
                                  KeyDown="ResultsListView_KeyDown"
                                  SelectionChanged="ResultsListView_SelectionChanged"
                                  ContainerContentChanging="ResultsListView_ContainerContentChanging"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#20202E"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#252535"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#2E2E42"/>
                                <SolidColorBrush x:Key="ListViewItemFocusBorderBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemFocusSecondaryBorderBrush" Color="Transparent"/>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="4,3,8,3"/>
                                    <Setter Property="Margin" Value="0,1,0,1"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="IsTabStop" Value="False"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:SearchResultItem">
                                    <Grid>
                                        <!-- Category header row -->
                                        <TextBlock Text="{x:Bind HeaderText}"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}"
                                                   CharacterSpacing="150"
                                                   Margin="10,10,0,2"
                                                   Visibility="{x:Bind HeaderVisibility}"/>
                                        <!-- Result item -->
                                        <Grid Visibility="{x:Bind ContentVisibility}"
                                              ColumnSpacing="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Accent bar -->
                                            <Border Grid.Column="0"
                                                    Width="3"
                                                    CornerRadius="2"
                                                    Background="{StaticResource AccentColor}"
                                                    VerticalAlignment="Stretch"
                                                    Opacity="0"/>
                                            <!-- Icon -->
                                            <Grid Grid.Column="2"
                                                  Width="38" Height="38"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind ResultIconVisibility}">
                                                <Border Width="38" Height="38"
                                                        CornerRadius="9"
                                                        Background="{StaticResource SurfaceCard}"/>
                                                <FontIcon Glyph="&#xE1D0;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind CalcVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon Glyph="&#xE756;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind ShellVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon Glyph="&#xE770;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind SystemCommandVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon Glyph="&#xE774;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind WebUrlVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon Glyph="&#xE721;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind WebSearchVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon Glyph="&#xEF58;"
                                                          FontFamily="{StaticResource IconFont}"
                                                          FontSize="20"
                                                          Foreground="{StaticResource AccentColor}"
                                                          Visibility="{x:Bind AIVisibility}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <Image Source="{x:Bind IconSource}"
                                                       Width="28" Height="28"
                                                       Stretch="Uniform"
                                                       Visibility="{x:Bind ImageVisibility}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Text -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontSize="14"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind CalcResult}"
                                                           FontSize="20"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentColor}"
                                                           Visibility="{x:Bind CalcVisibility}"/>
                                                <TextBlock Text="{x:Bind AIResponse, Mode=OneWay}"
                                                           FontSize="12"
                                                           FontFamily="{StaticResource BodyFont}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextWrapping="Wrap"
                                                           Visibility="{x:Bind AIVisibility}"/>
                                                <TextBlock Text="{x:Bind Path}"
                                                           FontSize="11"
                                                           FontFamily="{StaticResource BodyFont}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{x:Bind UwpVisibility}"/>
                                            </StackPanel>
                                            <!-- Enter hint -->
                                            <Border Grid.Column="5"
                                                    Background="{StaticResource SurfaceCard}"
                                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="7,3,7,3"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="&#x23CE;"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyResultsPanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,20">
                            <FontIcon Glyph="&#xE9CE;"
                                      FontFamily="{StaticResource IconFont}"
                                      FontSize="32"
                                      Foreground="{StaticResource TextMuted}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyResultsText"
                                       Text="No results found"
                                       FontSize="18"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyResultsDescText"
                                       Text="Try a different search term"
                                       FontSize="13"
                                       FontFamily="{StaticResource BodyFont}"
                                       Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- AI CHAT PANEL -->
                        <ScrollViewer x:Name="AiChatPanel" Visibility="Collapsed" Margin="8,6,8,6" VerticalScrollBarVisibility="Hidden" Opacity="0">
                            <ScrollViewer.RenderTransform>
                                <TranslateTransform x:Name="AiChatPanelTransform" Y="12"/>
                            </ScrollViewer.RenderTransform>
                            <StackPanel Spacing="16" Margin="14,14,14,14">
                                <!-- User Prompt Bubble -->
                                <StackPanel Spacing="6" HorizontalAlignment="Right" MaxWidth="540">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                        <TextBlock x:Name="AiChatUserLabel" Text="YOU" FontSize="10" FontFamily="{StaticResource DisplayFont}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        <FontIcon Glyph="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Background="{StaticResource AccentDim}" CornerRadius="14,14,4,14" Padding="14,12,14,12" BorderBrush="{StaticResource AccentBorder}" BorderThickness="0.4">
                                        <TextBlock x:Name="AiChatUserPromptText" Text="What is openrouter?" FontSize="13.5" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" IsTextSelectionEnabled="True" LineHeight="20"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- AI Response Bubble -->
                                <StackPanel x:Name="AiResponsePanel" 
                                            Spacing="6" 
                                            HorizontalAlignment="Left" 
                                            MaxWidth="540"
                                            Background="Transparent"
                                            PointerEntered="AiResponsePanel_PointerEntered"
                                            PointerExited="AiResponsePanel_PointerExited">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Left">
                                        <FontIcon Glyph="&#xEF58;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AiChatAILabel" Text="AI RESPONSE" FontSize="10" FontFamily="{StaticResource DisplayFont}" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Background="{StaticResource SurfaceCard}" CornerRadius="14,14,14,4" Padding="14,12,14,12" BorderThickness="1">
                                        <!-- Top border accent glow -->
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#4A3FAA" Offset="0"/>
                                                <GradientStop Color="#303030" Offset="0.1"/>
                                                <GradientStop Color="#303030" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressRing x:Name="AiThinkingRing" Grid.Column="0" Width="16" Height="16" IsActive="False" Visibility="Collapsed" Foreground="{StaticResource AccentColor}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                            <RichTextBlock x:Name="AiChatResponseRichText" Grid.Column="1" FontSize="13.5" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextPrimary}" IsTextSelectionEnabled="True" LineHeight="21"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Subtitle (Model Info + Copy Button) shown on hover -->
                                    <Grid x:Name="AiResponseSubtitle" Visibility="Collapsed" Margin="4,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AiChatModelInfoText" 
                                                   Text="" 
                                                   FontSize="11" 
                                                   FontFamily="{StaticResource BodyFont}" 
                                                   Foreground="{StaticResource TextMuted}" 
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="AiCopyResponseButton" 
                                                Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="6,4,6,4"
                                                VerticalAlignment="Center"
                                                Click="AiCopyResponseButton_Click"
                                                ToolTipService.ToolTip="Copy response">
                                            <FontIcon Glyph="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                <!-- Vertical divider -->
                <Rectangle x:Name="VerticalDivider"
                           Grid.Column="1"
                           Width="1"
                           Fill="{StaticResource DividerBrush}"
                           Opacity="0.7"
                           Margin="0,10,0,10"
                           Visibility="Collapsed"/>
                <!-- DETAIL PANEL -->
                <Grid Grid.Column="2" x:Name="DetailPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Icon + Name -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="16,22,16,12" Spacing="10">
                        <Grid Width="80" Height="80" HorizontalAlignment="Center">
                            <Ellipse Width="80" Height="80"
                                     Fill="{StaticResource AccentGlow}"
                                     Opacity="0.6"/>
                            <Border CornerRadius="18"
                                    Width="68" Height="68"
                                    Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1">
                                <Grid>
                                    <FontIcon x:Name="DetailCalcIcon"
                                               Glyph="&#xE1D0;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailHelpIcon"
                                               Glyph="&#xE897;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailShellIcon"
                                               Glyph="&#xE756;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailSystemIcon"
                                               Glyph="&#xE770;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailWebIcon"
                                               Glyph="&#xE774;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailSearchIcon"
                                               Glyph="&#xE721;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DetailAIIcon"
                                               Glyph="&#xEF58;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentColor}"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Image x:Name="DetailAppIcon"
                                           Width="48" Height="48"
                                           Stretch="Uniform"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="DetailTitleText"
                                   Text="App Name"
                                   FontSize="15"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="250"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Border x:Name="TypeBadge"
                                CornerRadius="20"
                                Padding="10,4,10,4"
                                Background="{StaticResource AccentDim}"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="TypeBadgeText"
                                       Text="Win32"
                                       FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentHoverColor}"/>
                        </Border>
                    </StackPanel>
                    <!-- Metadata -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Spacing="14" Margin="16,4,16,4">
                            <StackPanel x:Name="DetailPathContainer" Spacing="5">
                                <TextBlock x:Name="DetailTypeLocationLabel" Text="LOCATION"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <Border Background="{StaticResource SurfaceCard}" CornerRadius="6"
                                        Padding="10,7,10,7" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1">
                                    <TextBlock x:Name="DetailPathText"
                                               Text="C:\Program Files\…"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="DetailAumidContainer" Spacing="5" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTypeAppIdLabel" Text="APP ID"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <Border Background="{StaticResource SurfaceCard}" CornerRadius="6"
                                        Padding="10,7,10,7" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1">
                                    <TextBlock x:Name="DetailAumidText"
                                               Text="Microsoft.App_…"
                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="DetailEquationContainer" Spacing="5" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTypeExpressionLabel" Text="EXPRESSION"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="DetailEquationText"
                                           Text="2 + 2"
                                           FontSize="14" FontFamily="{StaticResource MonoFont}"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel x:Name="DetailResultContainer" Spacing="5" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTypeResultLabel" Text="RESULT"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="DetailResultText"
                                           Text="4"
                                           FontSize="28" FontFamily="{StaticResource MonoFont}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentColor}"/>
                            </StackPanel>
                            <StackPanel x:Name="DetailCommandContainer" Spacing="5" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTypeCommandLabel" Text="COMMAND"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <Border Background="{StaticResource SurfaceCard}" CornerRadius="6"
                                        Padding="10,7,10,7" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1">
                                    <TextBlock x:Name="DetailCommandText"
                                               Text="ipconfig"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="DetailHelpContainer" Spacing="5" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTypeHelpLabel" Text="HELP &amp; DESCRIPTION"
                                           FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="SemiBold" CharacterSpacing="150"
                                           Foreground="{StaticResource TextMuted}"/>
                                <Border Background="{StaticResource SurfaceCard}" CornerRadius="6"
                                        Padding="12,10,12,10" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1">
                                    <TextBlock x:Name="DetailHelpText"
                                               Text="Description of shortcut or feature..."
                                               FontSize="12" FontFamily="{StaticResource BodyFont}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="DetailAIContainer" Spacing="12" Visibility="Collapsed">
                                <!-- User Prompt Bubble -->
                                <StackPanel Spacing="4" HorizontalAlignment="Right" MaxWidth="210">
                                    <TextBlock x:Name="DetailUserLabel"
                                               Text="YOU" 
                                               FontSize="9" 
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="Bold" 
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Right"
                                               CharacterSpacing="100"/>
                                    <Border Background="{StaticResource AccentDim}" 
                                            CornerRadius="12,12,2,12" 
                                            Padding="10,8,10,8"
                                            BorderThickness="0">
                                        <TextBlock x:Name="DetailUserPromptText"
                                                   Text="What is openrouter?"
                                                   FontSize="12" 
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap" 
                                                   IsTextSelectionEnabled="True"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- AI Response Bubble -->
                                <StackPanel Spacing="4" HorizontalAlignment="Left" MaxWidth="210">
                                    <TextBlock x:Name="DetailTypeAILabel" 
                                               Text="AI RESPONSE"
                                               FontSize="9" 
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="Bold" 
                                               Foreground="{StaticResource AccentColor}"
                                               HorizontalAlignment="Left"
                                               CharacterSpacing="100"/>
                                    <Border Background="{StaticResource SurfaceCard}" 
                                            CornerRadius="12,12,12,2" 
                                            Padding="12,9,12,9" 
                                            BorderBrush="{StaticResource SearchBoxBorder}" 
                                            BorderThickness="1">
                                        <TextBlock x:Name="DetailAIText"
                                                   Text="AI response will appear here..."
                                                   FontSize="12" 
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap" 
                                                   IsTextSelectionEnabled="True"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Spacing="4" Margin="16,0,16,14">
                        <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Opacity="0.6" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ActionTitleLabel" Text="ACTIONS"
                                   FontSize="9" FontFamily="{StaticResource DisplayFont}"
                                   FontWeight="SemiBold" CharacterSpacing="150"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                        <Grid x:Name="ActionOpenGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ActionOpenText" Text="Open" FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="5" Padding="7,3,7,3">
                                <TextBlock Text="Enter" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextMuted}"/>
                            </Border>
                        </Grid>
                        <Grid x:Name="ActionCopyResultGrid" ColumnSpacing="8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ActionCopyResultText" Text="Copy Result" FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="5" Padding="7,3,7,3">
                                <TextBlock Text="Enter" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextMuted}"/>
                            </Border>
                        </Grid>
                        <Grid x:Name="ActionAdminGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ActionRunAdminText" Text="Run as Admin" FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="5" Padding="7,3,7,3">
                                <TextBlock Text="Ctrl+Shift+Enter" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextMuted}"/>
                            </Border>
                        </Grid>
                        <Grid x:Name="ActionLocationGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ActionShowExplorerText" Text="Show in Explorer" FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="5" Padding="7,3,7,3">
                                <TextBlock Text="Ctrl+Shift+O" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextMuted}"/>
                            </Border>
                        </Grid>
                        <Grid x:Name="ActionCopyPathGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ActionCopyPathText" Text="Copy Path" FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="5" Padding="7,3,7,3">
                                <TextBlock Text="Ctrl+C" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextMuted}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
                <!-- SETTINGS VIEW -->
                <Grid x:Name="SettingsPanel"
                      Grid.Column="0" Grid.ColumnSpan="3"
                      Visibility="Collapsed"
                      Padding="18,16,18,12">
                    <!-- HEADER Grid (aligned to top) -->
                    <Grid VerticalAlignment="Top" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="BackToMainButton"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8"
                                    Content="&#xE72B;"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource TextPrimary}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#20202E"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#252535"/>
                                </Button.Resources>
                            </Button>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="8,0,0,0">
                                <Button x:Name="SettingsTabButton"
                                        Content="General"
                                        FontSize="16"
                                        FontFamily="{StaticResource DisplayFont}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimary}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,4,4,8"
                                        VerticalAlignment="Center">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                    </Button.Resources>
                                </Button>
                                <Button x:Name="HelpTabButton"
                                        Content="Help &amp; Shortcuts"
                                        FontSize="16"
                                        FontFamily="{StaticResource DisplayFont}"
                                        FontWeight="Normal"
                                        Foreground="{StaticResource TextMuted}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,4,4,8"
                                        VerticalAlignment="Center">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   x:Name="EscBackLabel"
                                   Text="ESC to go back"
                                   FontSize="11"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <!-- ScrollViewer with Margin to start below the header -->
                    <ScrollViewer x:Name="SettingsScrollViewer" Margin="0,50,0,0" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Spacing="14" Margin="0,0,12,0">
                            <!-- PREVIEW SECTION CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3" VerticalAlignment="Center">
                                        <TextBlock x:Name="SettingPreviewTitleText" Text="Show Preview Panel"
                                                   FontSize="14"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock x:Name="SettingPreviewDescText" Text="Display the right-hand preview panel when selecting apps or calculator results."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="450"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ShowPreviewToggle"
                                                  Grid.Column="1"
                                                  IsOn="True"
                                                  VerticalAlignment="Center">
                                        <ToggleSwitch.Resources>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#8B7FF0"/>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#A598F5"/>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#6C5FE6"/>
                                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#0E0E14"/>
                                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#8888AA"/>
                                        </ToggleSwitch.Resources>
                                    </ToggleSwitch>
                                </Grid>
                            </Border>
                            <!-- STARTUP CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3" VerticalAlignment="Center">
                                        <TextBlock x:Name="SettingStartupTitleText"
                                                   Text="Launch on System Startup"
                                                   FontSize="14"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock x:Name="SettingStartupDescText"
                                                   Text="Automatically start WinCast minimized to the system tray when you log in."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="450"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LaunchOnStartupToggle"
                                                  Grid.Column="1"
                                                  IsOn="False"
                                                  VerticalAlignment="Center">
                                        <ToggleSwitch.Resources>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#8B7FF0"/>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#A598F5"/>
                                            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#6C5FE6"/>
                                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#0E0E14"/>
                                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#8888AA"/>
                                        </ToggleSwitch.Resources>
                                    </ToggleSwitch>
                                </Grid>
                            </Border>
                            <!-- VISUAL THEME CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="3">
                                        <TextBlock x:Name="SettingBackdropTitleText" Text="Window Backdrop Style"
                                                   FontSize="14"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock x:Name="SettingBackdropDescText" Text="Tune the launcher surface while keeping the rounded frame."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                                            <TextBlock x:Name="SettingThemeText" Text="Theme"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingThemeDescText" Text="Choose the launcher color mode."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeModeComboBox"
                                                  Grid.Row="0" Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem Content="System"/>
                                            <ComboBoxItem Content="Dark"/>
                                            <ComboBoxItem Content="Light"/>
                                        </ComboBox>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                                            <TextBlock x:Name="SettingMaterialText" Text="Material"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingMaterialDescText" Text="Pick the Windows backdrop behind the rounded surface."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="BackdropComboBox"
                                                  Grid.Row="1" Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem Content="Mica"/>
                                            <ComboBoxItem Content="Acrylic"/>
                                            <ComboBoxItem Content="Solid"/>
                                        </ComboBox>
                                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="1">
                                            <TextBlock x:Name="SettingSurfaceText" Text="Surface"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingSurfaceDescText" Text="Control how much backdrop shows through the rounded panel."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="SurfaceOpacityComboBox"
                                                  Grid.Row="2" Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem Content="Subtle"/>
                                            <ComboBoxItem Content="Balanced"/>
                                            <ComboBoxItem Content="Glass"/>
                                        </ComboBox>
                                        <StackPanel Grid.Row="3" Grid.Column="0" Spacing="1">
                                            <TextBlock x:Name="SettingLanguageText" Text="Language"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingLanguageDescText" Text="Choose your interface language."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="LanguageComboBox"
                                                  Grid.Row="3" Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem Content="English" Tag="en"/>
                                            <ComboBoxItem Content="العربية" Tag="ar"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- AI INTEGRATION CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="3">
                                        <TextBlock x:Name="SettingAITitleText"
                                                   Text="AI Integration"
                                                   FontSize="14"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock x:Name="SettingAIDescText"
                                                   Text="Configure OpenRouter free LLM access. Prefix query with (-) to ask anything."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    
                                    <!-- AI Provider Dropdown -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="SettingAIProviderTitleText"
                                                       Text="AI Provider"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingAIProviderDescText"
                                                       Text="Choose between the default free router or a custom API key."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="AiProviderComboBox"
                                                  Grid.Column="1"
                                                  Width="220"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem x:Name="AiProviderFreeItem" Content="Free Models Router" Tag="Free"/>
                                            <ComboBoxItem x:Name="AiProviderCustomItem" Content="Custom API Key" Tag="Custom"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Model Selection dropdown (shown/hidden dynamically) -->
                                    <Grid x:Name="ModelSettingsGrid" ColumnSpacing="12" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="SettingModelTitleText"
                                                       Text="AI Model"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingModelDescText"
                                                       Text="Select which model to use."
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ModelComboBox"
                                                  Grid.Column="1"
                                                  Width="220"
                                                  VerticalAlignment="Center">
                                            <ComboBoxItem Content="Auto Free Router" Tag="openrouter/free"/>
                                            <ComboBoxItem Content="Gemini 2.5 Flash" Tag="google/gemini-2.5-flash"/>
                                            <ComboBoxItem Content="Claude 3.5 Sonnet" Tag="anthropic/claude-3.5-sonnet"/>
                                            <ComboBoxItem Content="GPT-4o" Tag="openai/gpt-4o"/>
                                            <ComboBoxItem Content="Llama 3.3 70B" Tag="meta-llama/llama-3.3-70b-instruct"/>
                                            <ComboBoxItem Content="DeepSeek V3" Tag="deepseek/deepseek-chat"/>
                                            <ComboBoxItem Content="DeepSeek R1" Tag="deepseek/deepseek-r1"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Custom API Key input (shown/hidden dynamically) -->
                                    <Grid x:Name="AiKeySettingsGrid" ColumnSpacing="12" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="SettingAIKeyHeaderText"
                                                       Text="OpenRouter API Key"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="SettingAIKeyDescText"
                                                       Text="Enter your OpenRouter API Key (sk-or-...)"
                                                       FontSize="11"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <PasswordBox x:Name="OpenRouterApiKeyBox"
                                                     Grid.Column="1"
                                                     Width="220"
                                                     PlaceholderText="Enter API Key"
                                                     PasswordChar="●"
                                                     VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- UPDATE CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3" VerticalAlignment="Center">
                                            <TextBlock x:Name="SettingUpdatesTitleText"
                                                       Text="Updates"
                                                       FontSize="14"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="CurrentVersionText"
                                                       Text="Current version"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Button x:Name="CheckUpdatesButton"
                                                Grid.Column="1"
                                                Content="Check"
                                                MinWidth="92"
                                                Padding="12,6,12,6"
                                                VerticalAlignment="Center"
                                                Click="CheckUpdatesButton_Click"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="UpdateStatusText"
                                                   Text="Check GitHub Releases for a newer installer."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="DownloadUpdateButton"
                                                Grid.Column="1"
                                                Content="Download and install"
                                                Padding="12,6,12,6"
                                                Visibility="Collapsed"
                                                VerticalAlignment="Center"
                                                Click="DownloadUpdateButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- SHORTCUTS INFO -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3" VerticalAlignment="Center">
                                        <TextBlock x:Name="SettingShortcutTitleText"
                                                   Text="Global Launcher Shortcut"
                                                   FontSize="14"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock x:Name="SettingShortcutDescText"
                                                   Text="The key combination used to toggle the WinCast launcher window."
                                                   FontSize="12"
                                                   FontFamily="{StaticResource BodyFont}"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource SearchBoxBorder}"
                                            BorderBrush="{StaticResource SearchBoxBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6,10,6"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Alt + Space"
                                                   FontSize="12"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentColor}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Help & Documentation ScrollViewer -->
                    <ScrollViewer x:Name="HelpScrollViewer" Margin="0,50,0,0" VerticalScrollBarVisibility="Hidden" Visibility="Collapsed">
                        <StackPanel Spacing="14" Margin="0,0,12,0">
                            <!-- KEYBOARD SHORTCUTS CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="HelpShortcutsTitleText"
                                               Text="Keyboard Shortcuts"
                                               FontSize="15"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentColor}"/>
                                    
                                    <Grid ColumnSpacing="16" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Row 0: Toggle Window -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="HelpShortcutsToggleTitleText" Text="Toggle WinCast Window" FontSize="13" FontFamily="{StaticResource DisplayFont}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="HelpShortcutsToggleDescText" Text="Show or hide the launcher window globally." FontSize="11" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource SearchBoxBorder}" BorderThickness="1" BorderBrush="{StaticResource SearchBoxBorder}" CornerRadius="5" Padding="6,3,6,3" VerticalAlignment="Center">
                                            <TextBlock Text="Alt + Space" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                        <!-- Row 1: Launch Selected -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="HelpShortcutsOpenTitleText" Text="Launch / Open Selected" FontSize="13" FontFamily="{StaticResource DisplayFont}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="HelpShortcutsOpenDescText" Text="Execute the highlighted application, command, or calculator result." FontSize="11" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource SearchBoxBorder}" BorderThickness="1" BorderBrush="{StaticResource SearchBoxBorder}" CornerRadius="5" Padding="6,3,6,3" VerticalAlignment="Center">
                                            <TextBlock Text="Enter" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                        <!-- Row 2: Run as Administrator -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="HelpShortcutsAdminTitleText" Text="Run as Administrator" FontSize="13" FontFamily="{StaticResource DisplayFont}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="HelpShortcutsAdminDescText" Text="Elevate execution for Win32 apps or Shell commands." FontSize="11" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource SearchBoxBorder}" BorderThickness="1" BorderBrush="{StaticResource SearchBoxBorder}" CornerRadius="5" Padding="6,3,6,3" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl + Shift + Enter" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                        <!-- Row 3: Open File Location -->
                                        <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="HelpShortcutsExplorerTitleText" Text="Show in File Explorer" FontSize="13" FontFamily="{StaticResource DisplayFont}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="HelpShortcutsExplorerDescText" Text="Reveal the application's executable in File Explorer." FontSize="11" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Row="3" Grid.Column="1" Background="{StaticResource SearchBoxBorder}" BorderThickness="1" BorderBrush="{StaticResource SearchBoxBorder}" CornerRadius="5" Padding="6,3,6,3" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl + Shift + O" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                        <!-- Row 4: Copy Value -->
                                        <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="HelpShortcutsCopyTitleText" Text="Copy Value / Path / Command" FontSize="13" FontFamily="{StaticResource DisplayFont}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="HelpShortcutsCopyDescText" Text="Copy the path, calculator output, or shell command string to clipboard." FontSize="11" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Row="4" Grid.Column="1" Background="{StaticResource SearchBoxBorder}" BorderThickness="1" BorderBrush="{StaticResource SearchBoxBorder}" CornerRadius="5" Padding="6,3,6,3" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl + C" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- SHELL COMMAND EXECUTOR CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="HelpShellTitleText"
                                               Text="Terminal &amp; Shell Commands"
                                               FontSize="15"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentColor}"/>
                                    <TextBlock x:Name="HelpShellDescText"
                                               Text="You can execute arbitrary shell commands directly from the search bar using the prefix: &gt;"
                                               FontSize="13" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                    <Border Background="{StaticResource AppBackground}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="6" Padding="12,10,12,10" Margin="0,4,0,4">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="HelpShellExampleText" Text="Example query:" FontSize="10" FontFamily="{StaticResource DisplayFont}" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="&gt; ping 8.8.8.8 -t" FontSize="13" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource CyanAccent}"/>
                                            <TextBlock Text="&gt; ipconfig /all" FontSize="13" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource CyanAccent}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="HelpShellBullet1Text" Text="• Pressing Enter opens a command prompt window executing the command." FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="HelpShellBullet2Text" Text="• Pressing Ctrl+Shift+Enter executes the command as Administrator." FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <!-- CALCULATOR CARD -->
                            <Border Background="{StaticResource SurfaceCard}"
                                    BorderBrush="{StaticResource SearchBoxBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="HelpCalcTitleText"
                                               Text="Instant Calculator"
                                               FontSize="15"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentColor}"/>
                                    <TextBlock x:Name="HelpCalcDescText"
                                               Text="Type any mathematical expression directly into the search bar. The result will instantly appear."
                                               FontSize="13" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                    <Border Background="{StaticResource AppBackground}" BorderBrush="{StaticResource SearchBoxBorder}" BorderThickness="1" CornerRadius="6" Padding="12,10,12,10" Margin="0,4,0,4">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="HelpCalcOperatorsText" Text="Supported operators: +, -, *, /, (, )" FontSize="10" FontFamily="{StaticResource DisplayFont}" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="(15 + 25) * 4" FontSize="13" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentColor}"/>
                                            <TextBlock Text="3.14 * 10 / 2" FontSize="13" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentColor}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="HelpCalcBullet1Text" Text="• Press Enter to instantly copy the calculated result to your clipboard." FontSize="12" FontFamily="{StaticResource BodyFont}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
            <!-- FOOTER -->
            <Grid Grid.Row="3"
                  Background="{StaticResource DetailPaneBackground}"
                  Padding="16,7,16,7"
                  CornerRadius="0,0,14,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock x:Name="FooterToggleText"
                               Text="Alt + Space Toggle"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="FooterNavigateText"
                               Text="&#x2191;&#x2193; Navigate"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="FooterLaunchText"
                               Text="&#x23CE; Launch"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="FooterDismissText"
                               Text="ESC Dismiss"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="FooterStatusText"
                               Text="Indexing…"
                               FontSize="10"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="FooterUpdateButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            Visibility="Collapsed"
                            Click="FooterUpdateButton_Click"
                            ToolTipService.ToolTip="Download and install update"
                            VerticalAlignment="Center">
                        <Grid Width="16" Height="16">
                            <FontIcon x:Name="FooterUpdateIcon"
                                      Glyph="&#xE896;"
                                      FontFamily="{StaticResource IconFont}"
                                      FontSize="14"
                                      Foreground="{StaticResource GreenAccent}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <ProgressRing x:Name="FooterUpdateRing"
                                          Width="16"
                                          Height="16"
                                          IsActive="False"
                                          Foreground="{StaticResource GreenAccent}"
                                          Visibility="Collapsed"/>
                        </Grid>
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#20202E"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#252535"/>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="SettingsButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            Content="&#xE713;"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#20202E"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#252535"/>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
