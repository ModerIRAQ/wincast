<Window
    x:Class="wincast.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wincast"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinCast">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar Header -->
        <Grid Grid.Row="0" Margin="16,14,16,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Icon -->
            <FontIcon Grid.Column="0" 
                      Glyph="&#xE721;" 
                      FontFamily="{StaticResource IconFont}" 
                      FontSize="20" 
                      Foreground="{StaticResource TextSecondary}"
                      VerticalAlignment="Center"/>

            <!-- Large Search TextBox -->
            <TextBox x:Name="SearchBox" 
                     Grid.Column="1" 
                     PlaceholderText="Search apps, calculate equations..." 
                     FontSize="18"
                     FontFamily="{StaticResource BodyFont}"
                     FontWeight="SemiLight"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,4,0,4"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     KeyDown="SearchBox_KeyDown">
                <TextBox.Resources>
                    <!-- Overrides default textBox border focus brushes to keep it borderless -->
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                </TextBox.Resources>
            </TextBox>

            <!-- Shortcut Indicator Badge -->
            <Border Grid.Column="2" 
                    Background="{StaticResource SearchBoxBorder}" 
                    CornerRadius="6" 
                    Padding="8,4,8,4" 
                    VerticalAlignment="Center">
                <TextBlock Text="Alt + Space" 
                           FontSize="11" 
                           FontFamily="{StaticResource DisplayFont}"
                           FontWeight="Medium" 
                           Foreground="{StaticResource TextMuted}"/>
            </Border>
        </Grid>

        <!-- Divider Line -->
        <MenuFlyoutSeparator Grid.Row="1" Background="{StaticResource SearchBoxBorder}" Height="1" Opacity="0.5"/>

        <!-- Results List -->
        <ListView x:Name="ResultsListView" 
                  Grid.Row="2" 
                  Margin="8,8,8,8"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="ResultsListView_ItemClick"
                  KeyDown="ResultsListView_KeyDown"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <ListView.Resources>
                <!-- Override ListViewItem lightweight styling tokens -->
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#2A2A35" Opacity="0.6"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#3A3A4A" Opacity="0.7"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#4A4A5A" Opacity="0.8"/>
            </ListView.Resources>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="10,8,10,8"/>
                    <Setter Property="Margin" Value="0,2,0,2"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:SearchResultItem">
                    <Grid ColumnSpacing="16" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- App / Calc Icon -->
                        <Grid Grid.Column="0" Width="36" Height="36" VerticalAlignment="Center">
                            <!-- Math Icon Fallback -->
                            <FontIcon Glyph="&#xE1D6;" 
                                      FontFamily="{StaticResource IconFont}" 
                                      FontSize="20" 
                                      Foreground="{StaticResource AccentColor}" 
                                      Visibility="{x:Bind GetCalcVisibility()}"/>
                            <!-- App Native Icon -->
                            <Image Source="{x:Bind IconSource}" 
                                   Stretch="Uniform" 
                                   Width="32" 
                                   Height="32"
                                   Visibility="{x:Bind GetUwpVisibility()}"/>
                        </Grid>

                        <!-- Search Text Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Name}" 
                                       FontSize="14" 
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimary}"/>
                            
                            <!-- Display calculated equation or exe path -->
                            <TextBlock Text="{x:Bind CalcResult}" 
                                       FontSize="18" 
                                       FontFamily="{StaticResource BodyFont}"
                                       FontWeight="Medium" 
                                       Foreground="{StaticResource AccentColor}"
                                       Visibility="{x:Bind GetCalcVisibility()}"/>
                            
                            <TextBlock Text="{x:Bind Path}" 
                                       FontSize="11" 
                                       FontFamily="{StaticResource BodyFont}"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind GetUwpVisibility()}"/>
                        </StackPanel>

                        <!-- Action Indicator (shown on hover/select or always in subtle styling) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.7">
                            <TextBlock Text="⏎ Open" 
                                       FontSize="11" 
                                       FontFamily="{StaticResource DisplayFont}"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom Footer Info Bar -->
        <Grid Grid.Row="3" Background="{StaticResource DetailPaneBackground}" Padding="16,8,16,8" CornerRadius="0,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Tips -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                <TextBlock Text="↑↓ Navigate" FontSize="11" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextMuted}"/>
                <TextBlock Text="⏎ Launch" FontSize="11" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextMuted}"/>
                <TextBlock Text="ESC Dismiss" FontSize="11" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       x:Name="FooterStatusText" 
                       Text="0 apps indexed" 
                       FontSize="11" 
                       FontFamily="{StaticResource DisplayFont}" 
                       Foreground="{StaticResource TextMuted}"/>
        </Grid>
    </Grid>
</Window>
